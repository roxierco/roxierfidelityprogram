# ---------- MERCADO PAGO (cobros a tus clientes) ----------
# Las consigues en: mercadopago.com.mx/developers -> Tus integraciones
# Empieza con las credenciales de PRUEBA (TEST-...) y cambia a producción al final.
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-secreto
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-tu-public-key

# Clave secreta para validar que los webhooks vienen realmente de Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=tu-secreto-de-webhook

# ---------- APP ----------
# La URL pública de tu aplicación. En desarrollo: http://localhost:3000
# En producción: https://roxierco.com
