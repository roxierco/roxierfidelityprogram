# ============================================================
#  ROXIER FIDELITY — Variables de entorno
# ============================================================
#  Copia este archivo y renómbralo a ".env.local" para desarrollo.
#  En Vercel, estas variables se configuran en:
#  Settings -> Environment Variables
#
#  IMPORTANTE: Las variables que empiezan con NEXT_PUBLIC_ son
#  visibles en el navegador (no pongas secretos ahí).
#  Las demás SOLO viven en el servidor (seguras).
# ============================================================

# ---------- SUPABASE (base de datos + login) ----------
# Las consigues en: supabase.com -> tu proyecto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-publica

# Esta clave es SECRETA — da acceso total a la base de datos.
# Solo se usa en el servidor. NUNCA la pongas con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-secreta

# ---------- MERCADO PAGO (cobros a tus clientes) ----------
# Las consigues en: mercadopago.com.mx/developers -> Tus integraciones
# Empieza con las credenciales de PRUEBA (TEST-...) y cambia a producción al final.
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-secreto
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-tu-public-key

# Clave secreta para validar que los webhooks vienen realmente de Mercado Pago.
# La consigues en: Developers -> tu app -> Webhooks -> Clave secreta.
MP_WEBHOOK_SECRET=tu-secreto-de-webhook

# ---------- APP ----------
# La URL pública de tu aplicación. En desarrollo: http://localhost:3000
# En producción: https://roxierco.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- PANEL DE ADMIN INTERNO ----------
# Secreto para consultar la auditoría de wallet (/api/admin/wallet-events).
# Solo tú lo usas; ponlo largo y aleatorio.
ADMIN_SECRET=un-secreto-largo-y-aleatorio

# ---------- APPLE WALLET (pases en iPhone) ----------
# Se generan con el certificado de Apple Developer. Todas son SECRETAS (server-only).
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_CERTIFICATE=
APPLE_WALLET_PRIVATE_KEY=
APPLE_WALLET_WWDR_CERTIFICATE=
APPLE_WALLET_AUTH_SECRET=

# ---------- GOOGLE WALLET (pases en Android) ----------
# De la cuenta de servicio de Google Wallet. Secretas (server-only).
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_SERVICE_ACCOUNT_PRIVATE_KEY=

# ---------- NOTIFICACIONES PUSH WEB (VAPID) ----------
# Genéralas con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:tu-correo@dominio.com

# ---------- RESEND (correos de promociones a tus clientes) ----------
# Consíguela en: resend.com -> API Keys. Verifica tu dominio para que no caiga en spam.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remitente con tu dominio verificado. Ejemplo: "Roxier Fidelity <no-reply@roxierco.com>"
EMAIL_FROM=Roxier Fidelity <no-reply@roxierco.com>

# ---------- PANEL ADMIN ----------
# Contraseña para acceder al panel /admin — cámbiala antes de producción
ADMIN_PASSWORD=cambia-esta-clave-segura-2024
