# ============================================================
#  ROXIER FIDELITY — Variables de entorno
# ============================================================
#  Copia este archivo y renómbralo a ".env.local" para desarrollo.
#  En Vercel, estas variables se configuran en:
#  Settings -> Environment Variables
#
#  IMPORTANTE: Las variables que empiezan con NEXT_PUBLIC_ son
#  visibles en el navegador (no pongas secretos ahí).
#  Las demás SOLO viven en el servidor (seguras).
# ============================================================

# ---------- SUPABASE (base de datos + login) ----------
# Las consigues en: supabase.com -> tu proyecto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-publica

# Esta clave es SECRETA — da acceso total a la base de datos.
# Solo se usa en el servidor. NUNCA la pongas con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-secreta

# ---------- MERCADO PAGO (cobros a tus clientes) ----------
# Las consigues en: mercadopago.com.mx/developers -> Tus integraciones
# Empieza con las credenciales de PRUEBA (TEST-...) y cambia a producción al final.
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-secreto
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-tu-public-key

# Clave secreta para validar que los webhooks vienen realmente de Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=tu-secreto-de-webhook

# ---------- APP ----------
# La URL pública de tu aplicación. En desarrollo: http://localhost:3000
# En producción: https://roxierco.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- APPLE / GOOGLE WALLET (se configuran en la Fase 4) ----------
# Déjalas vacías por ahora. Las llenaremos después del diseño y arquitectura.
# APPLE_PASS_TYPE_ID=
# APPLE_TEAM_ID=
# APPLE_CERT_BASE64=
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=
