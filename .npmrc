# No ejecutar scripts de instalación de las dependencias.
# Es la defensa principal contra ataques de cadena de suministro: si un
# paquete (o uno de sus sub-paquetes) es comprometido, su script de postinstall
# no correrá código en tu máquina ni en el build de Vercel.
ignore-scripts=true

# No instalar versiones publicadas hace menos de 3 días. Cuando secuestran un
# paquete de npm, casi siempre se detecta y se baja en horas; esta cuarentena
# evita agarrar la versión maliciosa recién publicada.
minimum-release-age=4320

# Versiones exactas al agregar dependencias (sin ^ ni ~), para que el build
# sea reproducible y nadie cuele una versión distinta sin que se note.
save-exact=true
